# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Shopify Storefront API
SHOPIFY_STORE_API_URL=https://your-store.myshopify.com/api/2024-01/graphql.json
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-access-token
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# ============================================================
# Shopify Admin API (for scripts only — not used at runtime)
# ============================================================
# Used by scripts/install-redirect-theme.js and future admin API scripts.
# Get from Shopify Admin > Settings > Apps > Develop apps > Admin API access token
# Token needs scopes: write_themes, read_themes
SHOPIFY_ADMIN_API_URL=https://mama-fern.myshopify.com/admin/api/2026-04/graphql.json
SHOPIFY_ADMIN_ACCESS_TOKEN=

# ============================================================
# Shopify App (OAuth / Admin)
# ============================================================
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# ============================================================
# Email (Brevo) — Enables contact form & newsletter
# ============================================================
BREVO_API_KEY=
BREVO_LIST_ID=
BREVO_BACK_IN_STOCK_LIST_ID=
BREVO_SENDER_EMAIL=hello@mamafern.com
CONTACT_TO_EMAIL=hello@mamafern.com

# ============================================================
# Google Analytics (Optional)
# ============================================================
# Set to your GA4 Measurement ID (e.g. G-XXXXXXXXXX) to enable analytics
NEXT_PUBLIC_GA_ID=

# ============================================================
# Social Media (Optional)
# ============================================================
# Add full URLs when accounts are ready. Leave blank to hide icons.
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_TIKTOK_URL=
NEXT_PUBLIC_PINTEREST_URL=

# ============================================================
# Cart Settings
# ============================================================
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD=70

# ============================================================
# Site URL (for sitemap, OG tags, etc.)
# ============================================================
NEXT_PUBLIC_SITE_URL=https://mamafern.com

# ============================================================
# Keystatic CMS — GitHub App Storage + Shared Password Gate
# ============================================================
NEXT_PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=mama-fern-cms
KEYSTATIC_SECRET=
KEYSTATIC_PASSWORD=

# ============================================================
# GitHub Webhook — Blog Content Sync (Optional)
# ============================================================
GITHUB_WEBHOOK_SECRET=

# ============================================================
# Hosting — Hostinger Node.js
# ============================================================
PORT=3000
NODE_ENV=production

# ============================================================
# Shop the Look Admin
# ============================================================
# Passphrase for the /lookadmin panel. Set to the same value for both.
# LOOK_ADMIN_PASS is server-side (protects API writes).
# NEXT_PUBLIC_LOOK_ADMIN_PASS is client-side (validates passphrase in browser).
LOOK_ADMIN_PASS=your-secret-passphrase-here
NEXT_PUBLIC_LOOK_ADMIN_PASS=your-secret-passphrase-here
