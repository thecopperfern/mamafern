# ============================================================
# Shopify Storefront API
# ============================================================
# REQUIRED: Get this from Shopify Admin > Settings > Apps and sales channels >
# Develop apps > [Your App] > API credentials > Storefront API access token
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=mama-fern.myshopify.com
SHOPIFY_STORE_API_URL=https://mama-fern.myshopify.com/api/2026-04/graphql.json
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# ============================================================
# Shopify Admin API (for scripts only — not used at runtime)
# ============================================================
# Used by scripts/install-redirect-theme.js and future admin API scripts.
# Get from Shopify Admin > Settings > Apps > Develop apps > Admin API access token
# Token needs scopes: write_themes, read_themes
SHOPIFY_ADMIN_API_URL=https://mama-fern.myshopify.com/admin/api/2026-04/graphql.json
SHOPIFY_ADMIN_ACCESS_TOKEN=

# ============================================================
# Shopify App (OAuth / Admin)
# ============================================================
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# ============================================================
# Email (Brevo) — Enables contact form & newsletter
# ============================================================
BREVO_API_KEY=
BREVO_LIST_ID=
BREVO_BACK_IN_STOCK_LIST_ID=
BREVO_SENDER_EMAIL=hello@mamafern.com
CONTACT_TO_EMAIL=hello@mamafern.com

# ============================================================
# Google Analytics (Optional)
# ============================================================
# Set to your GA4 Measurement ID (e.g. G-XXXXXXXXXX) to enable analytics
NEXT_PUBLIC_GA_ID=

# ============================================================
# Social Media (Optional)
# ============================================================
# Add full URLs when accounts are ready. Leave blank to hide icons.
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_TIKTOK_URL=
NEXT_PUBLIC_PINTEREST_URL=

# ============================================================
# Cart Settings
# ============================================================
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD=70

# ============================================================
# Site URL (for sitemap, OG tags, etc.)
# ============================================================
NEXT_PUBLIC_SITE_URL=https://mamafern.com

# ============================================================
# Keystatic CMS — GitHub App Storage + Shared Password Gate
# ============================================================
# In production, Keystatic commits blog posts directly to the GitHub repo
# via a GitHub App (not an OAuth App).
#
# Setup (one-time):
#   1. Create/configure your GitHub App at https://github.com/settings/apps
#      - The app must be installed on the thecopperfern/mamafern repo
#      - The app slug is the last part of the URL: github.com/apps/YOUR-SLUG
#   2. Generate KEYSTATIC_SECRET:  openssl rand -hex 32
#   3. Choose a KEYSTATIC_PASSWORD for your team (you pick it, then share it)
#   4. Add all three vars to Hostinger hPanel → Environment Variables
#
# Workflow for marketing team:
#   1. Go to https://mamafern.com/keystatic
#   2. Enter the shared KEYSTATIC_PASSWORD (30-day cookie — only once per month)
#   3. Sign in with GitHub App (one-time per browser)
#   4. Create/edit posts → Keystatic auto-commits MDX files to GitHub
#   5. On Hostinger, run: git pull → post appears immediately (no rebuild needed)
NEXT_PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=mama-fern-cms
KEYSTATIC_SECRET=
KEYSTATIC_PASSWORD=

# ============================================================
# GitHub Webhook — Blog Content Sync (Optional)
# ============================================================
# Enables automatic blog content sync from the "Blog" branch without
# a full site rebuild. Set up a webhook in GitHub repo settings:
#   URL: https://mamafern.com/api/webhook/github
#   Content type: application/json
#   Secret: same value as below
#   Events: Push only
# Generate with: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=

# ============================================================
# Hosting — Hostinger Node.js
# ============================================================
PORT=3000
NODE_ENV=production
